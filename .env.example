# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
TZ=America/New_York

# Horizons event-stats API
EVENT_STATS_API_URL=http://localhost:3000
EVENT_STATS_API_KEY=replace-me

# Pipe-separated sub-events.
# Each entry: eventName,subteamId,channelId,ISO8601_TIME
# Time is ISO 8601: HH:MM±HH:MM, HH:MM:SS±HH:MM, or HH:MM:SSZ. Fires once per
# day at the UTC instant that time describes. NOTE: the offset is fixed —
# pick the offset for the part of the year you care about (DST does not shift it).
SUB_EVENTS=Test Event,S08XXXXXXX,C08AAAAAAA,09:00-04:00|Boston Meetup,S08YYYYYYY,C08BBBBBBB,10:00-04:00

# Message tokens: {ping} -> subteam mention, {date} -> today's long-form date.
STANDUP_MESSAGE_TEMPLATE=:sunrise: Good morning {ping}! Standup for {date}. Drop your update below — stats attached. 📊
THREAD_MESSAGE=:thread: Reply here with your standup update!

# Reminder message posted in-thread. {mentions} -> space-separated <@U…> pings
# for everyone in the subteam who hasn't replied yet.
REMINDER_MESSAGE_TEMPLATE={mentions} — still need your standup update. 🙏

# Reminder cadence (minutes)
REMINDER_GRACE_MINUTES=120
REMINDER_INTERVAL_MINUTES=120

# When true: post every sub-event's standup once at startup and shorten the
# grace period to 15 seconds so reminder behavior can be exercised quickly.
DEBUG=false
